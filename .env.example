# Slack App credentials (from https://api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret

# ARKON Engine MCP endpoint (existing deployment)
ARKON_MCP_URL=https://your-engine-hostname/api/alice-mcp
ARKON_TENANT_ID=your-tenant-id

# Optional MCP auth. Prefer the bearer token form unless the server needs a custom header.
ARKON_ENGINE_TOKEN=
# ARKON_MCP_AUTH_HEADER=X-Api-Key
# ARKON_MCP_AUTH_VALUE=your-api-key

# Legacy fallback if ARKON_MCP_URL is unset: the app posts to ${ARKON_ENGINE_URL}/alice-mcp.
# ARKON_ENGINE_URL=https://your-engine-hostname/api/alice

# Optional
PORT=3000
NODE_ENV=development
